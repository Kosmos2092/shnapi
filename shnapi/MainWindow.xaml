<!--
    MainWindow.xaml — View в паттерне MVVM.

    ИЗМЕНЕНИЕ относительно предыдущей лабораторной:
    Убрана жёсткая привязка DataContext из XAML:
        <Window.DataContext>
            <vm:MainViewModel />   ← БЫЛО (жёсткая связность)
        </Window.DataContext>
    Теперь DataContext устанавливается в конструкторе MainWindow.xaml.cs,
    куда MainViewModel приходит через DI-контейнер.
    XAML больше не создаёт ViewModel самостоятельно.
-->
<Window x:Class="shnapi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Телефонная книга" Height="480" Width="560"
        ResizeMode="CanMinimize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <!-- ====================================================
             ФОРМА ДОБАВЛЕНИЯ КОНТАКТА
             ==================================================== -->
        <GroupBox Grid.Row="0" Header="Новый контакт" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"  />
                    <ColumnDefinition Width="*"   />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8"    />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0"
                       Content="Имя:" VerticalAlignment="Center" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center" />

                <Label Grid.Row="2" Grid.Column="0"
                       Content="Тел.:" VerticalAlignment="Center" />
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding NewPhone, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center" />

                <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                        Content="Добавить"
                        Command="{Binding AddCommand}"
                        Margin="8,0,0,0" />
            </Grid>
        </GroupBox>

        <!-- ====================================================
             СТРОКА ОШИБКИ ВАЛИДАЦИИ
             ==================================================== -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ValidationError}"
                   Foreground="Red"
                   FontSize="12"
                   Margin="0,0,0,6">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ValidationError}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- ====================================================
             СПИСОК КОНТАКТОВ
             ==================================================== -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Contacts}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserResizeRows="False">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя"
                                    Binding="{Binding Name}"
                                    Width="*" />
                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding Phone}"
                                    Width="160" />

                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Удалить"
                                    Command="{Binding DataContext.DeleteCommand,
                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Padding="4,2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

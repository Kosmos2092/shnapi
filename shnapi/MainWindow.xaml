<!--
    ============================================================
    VIEW (Представление) в паттерне MVVM
    Отвечает только за отображение данных и взаимодействие с пользователем.
    НЕ содержит бизнес-логики — вся логика находится в MainViewModel.
    Данные получает исключительно через Data Binding.
    ============================================================
-->
<Window x:Class="shnapi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:shnapi.ViewModels"
        Title="Телефонная книга" Height="480" Width="560"
        ResizeMode="CanMinimize">

    <!--
        DataContext — ключевой элемент MVVM.
        Указывает, какой ViewModel обслуживает это окно.
        Все привязки {Binding ...} ищут свойства именно здесь.
    -->
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <!-- ====================================================
             ФОРМА ДОБАВЛЕНИЯ КОНТАКТА
             ==================================================== -->
        <GroupBox Grid.Row="0" Header="Новый контакт" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"  />
                    <ColumnDefinition Width="*"   />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8"    />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0"
                       Content="Имя:" VerticalAlignment="Center" />

                <!--
                    Двусторонняя привязка (Mode=TwoWay — по умолчанию для TextBox.Text).
                    UpdateSourceTrigger=PropertyChanged — ViewModel получает новое значение
                    при каждом нажатии клавиши, что позволяет CanExecute реагировать мгновенно.
                -->
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center" />

                <Label Grid.Row="2" Grid.Column="0"
                       Content="Тел.:" VerticalAlignment="Center" />

                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding NewPhone, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center" />

                <!--
                    Command="{Binding AddCommand}" — привязка кнопки к ICommand во ViewModel.
                    WPF автоматически блокирует кнопку, если CanExecute() возвращает false.
                    Никакого обработчика Click в code-behind не требуется.
                -->
                <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="2"
                        Content="Добавить"
                        Command="{Binding AddCommand}"
                        Margin="8,0,0,0" />
            </Grid>
        </GroupBox>

        <!-- ====================================================
             СТРОКА ОШИБКИ ВАЛИДАЦИИ
             Отображается только если ValidationError не пустой.
             DataTrigger скрывает блок когда текст равен "".
             ==================================================== -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ValidationError}"
                   Foreground="Red"
                   FontSize="12"
                   Margin="0,0,0,6">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ValidationError}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- ====================================================
             СПИСОК КОНТАКТОВ (DataGrid)
             ItemsSource привязан к ObservableCollection<Contact>.
             DataGrid обновляется автоматически при изменении коллекции.
             ==================================================== -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Contacts}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserResizeRows="False">

            <DataGrid.Columns>

                <!-- Столбец "Имя" — привязан к свойству Contact.Name -->
                <DataGridTextColumn Header="Имя"
                                    Binding="{Binding Name}"
                                    Width="*" />

                <!-- Столбец "Телефон" — привязан к свойству Contact.Phone -->
                <DataGridTextColumn Header="Телефон"
                                    Binding="{Binding Phone}"
                                    Width="160" />

                <!--
                    Кнопка удаления в каждой строке DataGrid.
                    CommandParameter="{Binding}" — передаёт объект Contact текущей строки
                    в DeleteCommand как параметр (DeleteCommand — с параметром).

                    Важно: внутри DataTemplate DataContext = Contact, а не ViewModel.
                    Поэтому добираемся до DeleteCommand через RelativeSource AncestorType=DataGrid,
                    у которого DataContext уже является MainViewModel.
                -->
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Удалить"
                                    Command="{Binding DataContext.DeleteCommand,
                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Padding="4,2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
